:LearnedMove a owl:Class ;
    rdfs:label "Learned Move" ;
    rdfs:comment "Reification (DUL Descriptions-and-Situations pattern) of a Pokémon's level-up move learning event. A Situation that holds together a Pokémon, a specific Move, and the level at which it is learned (Generation 3 / Emerald)." ;
    rdfs:subClassOf dul:Situation .

