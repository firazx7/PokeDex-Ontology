:SpecialMove a owl:Class ;
    rdfs:label "Special Move"@en ;
    rdfs:subClassOf :Move ;
    owl:equivalentClass [ a owl:Class ;
            owl:intersectionOf ( :Move [ a owl:Restriction ;
                        owl:hasValue :Special ;
                        owl:onProperty :hasMoveCategory ] ) ] .

