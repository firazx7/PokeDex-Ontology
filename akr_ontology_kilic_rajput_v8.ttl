dul:Description a owl:Class .

dul:Quality a owl:Class .

dul:Task a owl:Class .

<http://www.uni-bremen.de/akr/pokedex> a owl:Ontology ;
    rdfs:label "Pokémon Pokédex Ontology"@en ;
    dc:creator "Firaz Kilic",
        "Prakhar Rajput" ;
    dc:date "2026-06-03" ;
    dc:source "Pokémon Database (https://pokemondb.net/pokedex/all) - cross-reference for Pokémon stats and typings",
        "Pokémon Database (https://pokemondb.net/type) - canonical reference for the type effectiveness matrix",
        "Triply Academy Pokémon dataset (https://triplydb.com/academy/pokemon) - primary source for Pokémon individuals and stats" ;
    rdfs:comment "An ontology representing Pokémon, their types, moves, abilities and type effectiveness. Designed to back a roguelike-style battle game in which the player builds a team and SPARQL queries determine the best matchup against each opponent. The schema covers all 18 elemental types with the full Gen 6+ effectiveness matrix. Pokémon individuals are imported from the Triply Academy Pokémon dataset via a SPARQL CONSTRUCT query (scope: Gen 1-3, national #1-386). Grounded in the SOMA top-level ontology."@en ;
    owl:versionIRI <http://www.uni-bremen.de/akr/pokedex/0.2> .

