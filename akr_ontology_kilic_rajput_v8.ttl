:BugPokemon a owl:Class ;
    rdfs:label "Bug Pokémon"@en ;
    rdfs:subClassOf :Pokemon ;
    owl:equivalentClass [ a owl:Class ;
            owl:intersectionOf ( :Pokemon [ a owl:Restriction ;
                        owl:hasValue :Bug ;
                        owl:onProperty :hasType ] ) ] .

