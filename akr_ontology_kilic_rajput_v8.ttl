:StarterPokemon a owl:Class ;
    rdfs:label "Starter Pokémon"@en ;
    rdfs:comment "Defined class: a Pokémon that is available as a starter choice in the game."@en ;
    rdfs:subClassOf :Pokemon ;
    owl:equivalentClass [ a owl:Class ;
            owl:intersectionOf ( :Pokemon [ a owl:Restriction ;
                        owl:hasValue :Starter ;
                        owl:onProperty :belongsToCategory ] ) ] .

:StatusMove a owl:Class ;
    rdfs:label "Status Move"@en ;
    rdfs:subClassOf :Move ;
    owl:equivalentClass [ a owl:Class ;
            owl:intersectionOf ( :Move [ a owl:Restriction ;
                        owl:hasValue :Status ;
                        owl:onProperty :hasMoveCategory ] ) ] .

