:accuracy a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "accuracy"@en ;
    rdfs:domain :Move ;
    rdfs:range xsd:integer .

:baseAttack a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "base attack"@en ;
    rdfs:domain :Pokemon ;
    rdfs:range xsd:integer .

:baseDefense a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "base defense"@en ;
    rdfs:domain :Pokemon ;
    rdfs:range xsd:integer .

:baseExp a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "base experience"@en ;
    rdfs:domain :Pokemon ;
    rdfs:range xsd:integer .

:baseHP a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "base HP"@en ;
    rdfs:comment "Base health points statistic."@en ;
    rdfs:domain :Pokemon ;
    rdfs:range xsd:integer .

:baseSpAtk a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "base special attack"@en ;
    rdfs:domain :Pokemon ;
    rdfs:range xsd:integer .

:baseSpDef a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "base special defense"@en ;
    rdfs:domain :Pokemon ;
    rdfs:range xsd:integer .

:baseSpeed a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "base speed"@en ;
    rdfs:domain :Pokemon ;
    rdfs:range xsd:integer .

:belongsToGeneration a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "belongs to generation"@en ;
    rdfs:domain :Pokemon ;
    rdfs:range :Generation .

:causesStatus a owl:ObjectProperty ;
    rdfs:label "causes status"@en ;
    rdfs:domain :Move ;
    rdfs:range :StatusEffect .

:colour a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "colour"@en ;
    rdfs:comment "Primary colour classification of the Pokémon."@en ;
    rdfs:domain :Pokemon ;
    rdfs:range xsd:string .

:effectDescription a owl:DatatypeProperty ;
    rdfs:label "effect description"@en ;
    rdfs:domain :Ability ;
    rdfs:range xsd:string .

:evolvesTo a owl:ObjectProperty ;
    rdfs:label "evolves to"@en ;
    rdfs:comment "Pre-evolution → post-evolution. Inverse of :evolvesFrom."@en ;
    rdfs:domain :Pokemon ;
    rdfs:range :Pokemon ;
    owl:inverseOf :evolvesFrom .

:happiness a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "base happiness"@en ;
    rdfs:comment "Base friendship/happiness value, used for friendship-based evolutions."@en ;
    rdfs:domain :Pokemon ;
    rdfs:range xsd:integer .

:hasEvolutionMethod a owl:ObjectProperty ;
    rdfs:label "has evolution method"@en ;
    rdfs:domain :Pokemon ;
    rdfs:range :EvolutionMethod .

:hasHiddenAbility a owl:ObjectProperty ;
    rdfs:label "has hidden ability" ;
    rdfs:domain :Pokemon ;
    rdfs:range :Ability ;
    rdfs:subPropertyOf :hasAbility .

:hasMove a owl:ObjectProperty ;
    rdfs:label "has move"@en ;
    rdfs:comment "Relates a Pokémon to a move it knows."@en ;
    rdfs:domain :Pokemon ;
    rdfs:range :Move .

:hasMoveType a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "has move type"@en ;
    rdfs:comment "Every move has exactly one elemental type, which determines its effectiveness."@en ;
    rdfs:domain :Move ;
    rdfs:range :Type .

:hasNoEffectOn a owl:ObjectProperty ;
    rdfs:label "has no effect on"@en ;
    rdfs:comment "Deals 0× damage (immunity)."@en ;
    rdfs:domain :Type ;
    rdfs:range :Type .

:hasSpecies a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "has species"@en ;
    rdfs:comment "Every Pokémon has exactly one species classification."@en ;
    rdfs:domain :Pokemon ;
    rdfs:range :Species .

:height a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "height"@en ;
    rdfs:comment "Height in metres (or comparable unit from source)."@en ;
    rdfs:domain :Pokemon ;
    rdfs:range xsd:decimal .

:isNotVeryEffectiveAgainst a owl:ObjectProperty ;
    rdfs:label "is not very effective against"@en ;
    rdfs:comment "Deals 0.5× damage."@en ;
    rdfs:domain :Type ;
    rdfs:range :Type .

:isSuperEffectiveAgainst a owl:ObjectProperty ;
    rdfs:label "is super effective against"@en ;
    rdfs:comment "Deals 2× damage. Note: not symmetric. E.g. Ground is super effective against Fire, but Fire is not super effective against Ground."@en ;
    rdfs:domain :Type ;
    rdfs:range :Type .

:learnLevel a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "learn level" ;
    rdfs:comment "The Pokémon level at which a move is learned via level-up (Generation 3 / Emerald). A value of 0 or 1 indicates the move is known from the start." ;
    rdfs:domain :LearnedMove ;
    rdfs:range xsd:integer .

:learnsMove a owl:ObjectProperty ;
    rdfs:label "learns move" ;
    rdfs:comment "Relates a Pokémon to a LearnedMove situation (level-up learnset, Gen 3 / Emerald)." ;
    rdfs:domain :Pokemon ;
    rdfs:range :LearnedMove .

:nationalNumber a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "national Pokédex number"@en ;
    rdfs:comment "Unique identifier in the National Pokédex (1-1025+)."@en ;
    rdfs:domain :Pokemon ;
    rdfs:range xsd:integer .

:ofMove a owl:FunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "of move" ;
    rdfs:comment "Relates a LearnedMove situation to the specific Move that is learned." ;
    rdfs:domain :LearnedMove ;
    rdfs:range :Move .

:originatesFromRegion a owl:ObjectProperty ;
    rdfs:label "originates from region"@en ;
    rdfs:domain :Pokemon ;
    rdfs:range :Region .

:ownsPokemon a owl:ObjectProperty ;
    rdfs:label "owns Pokémon"@en ;
    rdfs:comment "Connects a trainer to the Pokémon in their team."@en ;
    rdfs:domain :Trainer ;
    rdfs:range :Pokemon .

:power a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "power"@en ;
    rdfs:domain :Move ;
    rdfs:range xsd:integer .

:pp a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "PP"@en ;
    rdfs:domain :Move ;
    rdfs:range xsd:integer .

:rareness a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "capture rate"@en ;
    rdfs:comment "Capture rate (rareness). Higher = easier to catch."@en ;
    rdfs:domain :Pokemon ;
    rdfs:range xsd:integer .

:usesItem a owl:ObjectProperty ;
    rdfs:label "uses item"@en ;
    rdfs:domain :Pokemon ;
    rdfs:range :Item .

:weight a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "weight"@en ;
    rdfs:comment "Weight in kilograms (or comparable unit from source)."@en ;
    rdfs:domain :Pokemon ;
    rdfs:range xsd:decimal .

soma:DesignedArtifact a owl:Class ;
    rdfs:subClassOf dul:Object .

soma:State a owl:Class ;
    rdfs:subClassOf dul:Concept .

dul:Action a owl:Class ;
    rdfs:subClassOf dul:Event .

dul:Event a owl:Class .

dul:PhysicalPlace a owl:Class .

dul:Situation a owl:Class .

